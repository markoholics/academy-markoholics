{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js",    "use": "@vercel/node" },
    { "src": "**/*.html",      "use": "@vercel/static" },
    { "src": "**/*.png",       "use": "@vercel/static" },
    { "src": "**/*.jpg",       "use": "@vercel/static" },
    { "src": "**/*.jpeg",      "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/blog/how-to-adapt-to-googles-agentic-ai-search-brand-playbook", "dest": "/blog/how-to-adapt-to-googles-agentic-ai-search-brand-playbook/index.html" },
    { "src": "/blog/how-to-adapt-to-googles-agentic-ai-search-brand-playbook/", "dest": "/blog/how-to-adapt-to-googles-agentic-ai-search-brand-playbook/index.html" },
    { "src": "/blog",     "dest": "/blog/index.html" },
    { "src": "/blog/",    "dest": "/blog/index.html" },
    { "src": "/photo.jpg",  "dest": "/photo.jpg" },
    { "src": "/photo.jpeg", "dest": "/photo.jpeg" },
    { "src": "/logo.png",   "dest": "/logo.png" },
    { "src": "/(.*)",       "dest": "/index.html" }
  ]
}
