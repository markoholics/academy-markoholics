{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "photo.jpg",  "use": "@vercel/static" },
    { "src": "photo.jpeg", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/photo.jpg",  "dest": "/photo.jpg" },
    { "src": "/photo.jpeg", "dest": "/photo.jpeg" },
    { "src": "/(.*)",       "dest": "/index.html" }
  ]
}
