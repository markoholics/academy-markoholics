{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js",    "use": "@vercel/node" },
    { "src": "**/*.html",      "use": "@vercel/static" },
    { "src": "**/*.png",       "use": "@vercel/static" },
    { "src": "**/*.jpg",       "use": "@vercel/static" },
    { "src": "**/*.jpeg",      "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/blog/beyond-the-citation-monetizing-google-agentic-search-funnel",          "dest": "/blog/beyond-the-citation-monetizing-google-agentic-search-funnel/index.html" },
    { "src": "/blog/beyond-the-citation-monetizing-google-agentic-search-funnel/",         "dest": "/blog/beyond-the-citation-monetizing-google-agentic-search-funnel/index.html" },
    { "src": "/blog/synthetic-chokehold-how-to-build-owned-audience-agentic-era",  "dest": "/blog/synthetic-chokehold-how-to-build-owned-audience-agentic-era/index.html" },
    { "src": "/blog/synthetic-chokehold-how-to-build-owned-audience-agentic-era/", "dest": "/blog/synthetic-chokehold-how-to-build-owned-audience-agentic-era/index.html" },
    { "src": "/blog/google-ads-agentic-ai-era-search",                            "dest": "/blog/google-ads-agentic-ai-era-search/index.html" },
    { "src": "/blog/google-ads-agentic-ai-era-search/",                           "dest": "/blog/google-ads-agentic-ai-era-search/index.html" },
    { "src": "/blog/h2ai-framework-why-human-x-ai-beats-human-plus-ai",          "dest": "/blog/h2ai-framework-why-human-x-ai-beats-human-plus-ai/index.html" },
    { "src": "/blog/h2ai-framework-why-human-x-ai-beats-human-plus-ai/",         "dest": "/blog/h2ai-framework-why-human-x-ai-beats-human-plus-ai/index.html" },
    { "src": "/blog/how-to-adapt-to-googles-agentic-ai-search-brand-playbook",   "dest": "/blog/how-to-adapt-to-googles-agentic-ai-search-brand-playbook/index.html" },
    { "src": "/blog/how-to-adapt-to-googles-agentic-ai-search-brand-playbook/",  "dest": "/blog/how-to-adapt-to-googles-agentic-ai-search-brand-playbook/index.html" },
    { "src": "/blog",     "dest": "/blog/index.html" },
    { "src": "/blog/",    "dest": "/blog/index.html" },
    { "src": "/event",    "dest": "/event/index.html" },
    { "src": "/event/",   "dest": "/event/index.html" },
    { "src": "/photo.jpg",     "dest": "/photo.jpg" },
    { "src": "/photo.jpeg",    "dest": "/photo.jpeg" },
    { "src": "/logo.png",      "dest": "/logo.png" },
    { "src": "/og-image.png",  "dest": "/og-image.png" },
    { "src": "/privacy-policy",  "dest": "/privacy-policy/index.html" },
    { "src": "/privacy-policy/", "dest": "/privacy-policy/index.html" },
    { "src": "/terms",           "dest": "/terms/index.html" },
    { "src": "/terms/",          "dest": "/terms/index.html" },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "aipoweredsearch\\.academy\\.humantothepowerofai\\.com" }],
      "dest": "/event/index.html"
    },
    { "src": "/(.*)",            "dest": "/index.html" }
  ]
}
