{
  "version": 2,
  "builds": [
    { "src": "index.html",  "use": "@vercel/static" },
    { "src": "photo.jpg",   "use": "@vercel/static" },
    { "src": "photo.jpeg",  "use": "@vercel/static" },
    { "src": "logo.png",    "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/photo.jpg",  "dest": "/photo.jpg" },
    { "src": "/photo.jpeg", "dest": "/photo.jpeg" },
    { "src": "/logo.png",   "dest": "/logo.png" },
    { "src": "/(.*)",       "dest": "/index.html" }
  ]
}
